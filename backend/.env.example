# ─── Database ───
# Gunakan connection string dari cloud provider Anda:
#
# Neon.tech:
#   DATABASE_URL=postgresql://username:password@ep-xxxx-xxxx.region.aws.neon.tech/dbname?sslmode=require
#
# Supabase:
#   DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
#
# Railway:
#   DATABASE_URL=postgresql://postgres:password@xxxx.railway.app:5432/railway
#
# Lokal (tanpa Docker):
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/dompetku

DATABASE_URL=your_cloud_database_url_here

# ─── Auth ───
BETTER_AUTH_SECRET=change_me_to_a_random_32_char_string_here
BETTER_AUTH_URL=http://localhost:3001

# ─── Server ───
PORT=3001
FRONTEND_URL=http://localhost:5173
